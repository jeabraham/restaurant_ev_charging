{
  "openapi": "3.1.0",
  "info": {
    "title": "Restaurant EV Charging API",
    "version": "1.0.0"
  },
  "servers": [
    {
      "url": "https://web-production-1f8a2.up.railway.app"
    }
  ],
  "paths": {
    "/find-dining-chargers": {
      "post": {
        "summary": "Find Dining Chargers",
        "description": "Find EV chargers within walking distance of restaurants. Always call this before recommending any charger or restaurant pair. Use when the user asks about dining while charging or charging stops. Geocode the location if needed.",
        "operationId": "find_dining_chargers_find_dining_chargers_post",
        "requestBody": {
          "content": {
            "application/json": {
              "schema": {
                "$ref": "#/components/schemas/FindDiningChargersRequest"
              }
            }
          },
          "required": true
        },
        "responses": {
          "200": {
            "description": "Successful Response",
            "content": {
              "application/json": {
                "schema": {
                  "type": "object",
                  "properties": {
                    "search": {
                      "type": "object",
                      "properties": {
                        "latitude": { "type": "number" },
                        "longitude": { "type": "number" },
                        "radius_km": { "type": "number" },
                        "restaurant_radius_m": { "type": "integer" }
                      }
                    },
                    "search_location": { "type": "string", "nullable": true },
                    "results": {
                      "type": "array",
                      "items": {
                        "type": "object",
                        "properties": {
                          "restaurant": {
                            "type": "object",
                            "properties": {
                              "name": { "type": "string" },
                              "address": { "type": "string", "nullable": true },
                              "latitude": { "type": "number" },
                              "longitude": { "type": "number" },
                              "website": { "type": "string", "nullable": true },
                              "google_maps_url": { "type": "string" }
                            }
                          },
                          "charger": {
                            "type": "object",
                            "properties": {
                              "name": { "type": "string" },
                              "network": { "type": "string", "nullable": true },
                              "maximum_power_kw": { "type": "number" },
                              "status": { "type": "string" },
                              "compatibility_notes": { "type": "string", "nullable": true },
                              "openchargemap_url": { "type": "string" }
                            }
                          },
                          "distance": {
                            "type": "object",
                            "properties": {
                              "straight_line_metres": { "type": "number" },
                              "estimated_walking_time_minutes": { "type": "integer" },
                              "google_maps_walking_url": { "type": "string" }
                            }
                          },
                          "other_close_chargers": {
                            "type": "array",
                            "description": "Other chargers also within walking distance of this restaurant, sorted by distance. Omitted when none exist.",
                            "items": {
                              "type": "object",
                              "properties": {
                                "name": { "type": "string" },
                                "openchargemap_url": { "type": "string" },
                                "straight_line_metres": { "type": "number" },
                                "estimated_walking_time_minutes": { "type": "integer" }
                              }
                            }
                          }
                        }
                      }
                    },
                    "diagnostics": {
                      "type": "object",
                      "properties": {
                        "qualifying_chargers": { "type": "integer" },
                        "qualifying_restaurant_charger_pairs": { "type": "integer" },
                        "warnings": { "type": "array", "items": { "type": "string" } }
                      }
                    }
                  }
                }
              }
            }
          },
          "422": {
            "description": "Validation Error",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/HTTPValidationError"
                }
              }
            }
          }
        }
      }
    }
  },
  "components": {
    "schemas": {
      "FindDiningChargersRequest": {
        "properties": {
          "latitude": {
            "type": "number",
            "maximum": 90.0,
            "minimum": -90.0,
            "title": "Latitude",
            "description": "Latitude of the search centre in decimal degrees. Geocode the user's location if they provided a city or place name."
          },
          "longitude": {
            "type": "number",
            "maximum": 180.0,
            "minimum": -180.0,
            "title": "Longitude",
            "description": "Longitude of the search centre in decimal degrees. Geocode the user's location if they provided a city or place name."
          },
          "radius_km": {
            "type": "number",
            "maximum": 100.0,
            "exclusiveMinimum": 0.0,
            "title": "Radius Km",
            "default": 10,
            "description": "Search radius in kilometres around the centre point. Default 10 km is suitable for a town; increase for rural areas."
          },
          "restaurant_radius_m": {
            "type": "integer",
            "maximum": 2000.0,
            "exclusiveMinimum": 0.0,
            "title": "Restaurant Radius M",
            "default": 500,
            "description": "Maximum walking distance in metres between a charger and a restaurant. Default 500 m (~6 min walk)."
          },
          "nacs": {
            "type": "boolean",
            "title": "Nacs",
            "default": true,
            "description": "Include NACS (North American Charging Standard / Tesla-compatible) chargers."
          },
          "ccs": {
            "type": "boolean",
            "title": "Ccs",
            "default": true,
            "description": "Include CCS (Combined Charging System) DC fast chargers."
          },
          "tesla_only": {
            "type": "boolean",
            "title": "Tesla Only",
            "default": false,
            "description": "Restrict results to Tesla Supercharger network only. Overrides nacs and ccs filters when true."
          },
          "max_results": {
            "type": "integer",
            "maximum": 200,
            "exclusiveMinimum": 0,
            "title": "Max Results",
            "default": 30,
            "description": "Maximum number of charger-restaurant pairs to return. Keep low (10-15) to avoid response size limits."
          }
        },
        "additionalProperties": false,
        "type": "object",
        "required": [
          "latitude",
          "longitude"
        ],
        "title": "FindDiningChargersRequest"
      },
      "HTTPValidationError": {
        "properties": {
          "detail": {
            "items": {
              "$ref": "#/components/schemas/ValidationError"
            },
            "type": "array",
            "title": "Detail"
          }
        },
        "type": "object",
        "title": "HTTPValidationError"
      },
      "ValidationError": {
        "properties": {
          "loc": {
            "items": {
              "anyOf": [
                {
                  "type": "string"
                },
                {
                  "type": "integer"
                }
              ]
            },
            "type": "array",
            "title": "Location"
          },
          "msg": {
            "type": "string",
            "title": "Message"
          },
          "type": {
            "type": "string",
            "title": "Error Type"
          },
          "input": {
            "title": "Input"
          },
          "ctx": {
            "type": "object",
            "title": "Context"
          }
        },
        "type": "object",
        "required": [
          "loc",
          "msg",
          "type"
        ],
        "title": "ValidationError"
      }
    }
  }
}
