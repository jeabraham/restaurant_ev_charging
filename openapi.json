{
  "openapi": "3.1.0",
  "info": {
    "title": "Restaurant EV Charging API",
    "version": "1.0.0"
  },
  "servers": [
    {
      "url": "https://web-production-1f8a2.up.railway.app"
    }
  ],
  "paths": {
    "/find-dining-chargers": {
      "post": {
        "summary": "Find Dining Chargers",
        "description": "Find EV chargers within walking distance of restaurants. Always call this before recommending any charger or restaurant pair. Use when the user asks about dining while charging or charging stops. Geocode the location if needed.",
        "operationId": "find_dining_chargers_find_dining_chargers_post",
        "requestBody": {
          "content": {
            "application/json": {
              "schema": {
                "$ref": "#/components/schemas/FindDiningChargersRequest"
              }
            }
          },
          "required": true
        },
        "responses": {
          "200": {
            "description": "Successful Response",
            "content": {
              "application/json": {
                "schema": {
                  "type": "object",
                  "properties": {
                    "search": {
                      "type": "object",
                      "properties": {
                        "latitude": { "type": "number" },
                        "longitude": { "type": "number" },
                        "radius_km": { "type": "number" },
                        "restaurant_radius_m": { "type": "integer" },
                        "preferred_radius_m": { "type": "integer", "description": "Effective near/far boundary used for tiering (clamped to restaurant_radius_m)." }
                      }
                    },
                    "search_location": { "type": "string", "nullable": true },
                    "results": {
                      "type": "array",
                      "items": {
                        "type": "object",
                        "properties": {
                          "tier": {
                            "type": "string",
                            "enum": ["primary", "distant_good", "slow_charger", "fast_food", "other"],
                            "description": "Recommendation tier. 'primary' = good independent restaurant within preferred_radius_m of a DC fast charger — recommend these first. When none exist, offer the fallbacks: 'distant_good' (good restaurant, longer walk to a fast charger), 'slow_charger' (good restaurant at a slow L2 charger), 'fast_food' (highly-rated fast food/chain near a fast charger). 'other' = more heavily compromised."
                          },
                          "restaurant": {
                            "type": "object",
                            "properties": {
                              "name": { "type": "string" },
                              "address": { "type": "string", "nullable": true },
                              "latitude": { "type": "number" },
                              "longitude": { "type": "number" },
                              "website": { "type": "string", "nullable": true },
                              "google_maps_url": { "type": "string" },
                              "reviews": {
                                "type": "object",
                                "description": "Third-party review data. Present only when a matching business was found. Use rating, review_count, cuisine_types, and is_open_now when ranking and recommending restaurants.",
                                "nullable": true,
                                "properties": {
                                  "rating": { "type": "number", "description": "Average rating (e.g. 1–5 for Yelp)." },
                                  "review_count": { "type": "integer", "description": "Number of reviews." },
                                  "price_level": { "type": "string", "nullable": true, "description": "Price level indicator, e.g. '$', '$$', '$$$', '$$$$'." },
                                  "cuisine_types": { "type": "array", "items": { "type": "string" }, "description": "Cuisine or category labels from the review provider." },
                                  "is_open_now": { "type": "boolean", "nullable": true, "description": "Whether the restaurant is currently open. Null if unknown." },
                                  "is_fast_food": { "type": "boolean", "description": "Whether the restaurant is classified as fast food by the review provider." },
                                  "provider_url": { "type": "string", "description": "Direct link to the restaurant's page on the review provider." },
                                  "provider": { "type": "string", "description": "Review data source, e.g. 'yelp'." }
                                }
                              }
                            }
                          },
                          "charger": {
                            "type": "object",
                            "properties": {
                              "name": { "type": "string" },
                              "network": { "type": "string", "nullable": true },
                              "maximum_power_kw": { "type": "number" },
                              "charger_speed": { "type": "string", "enum": ["DC_FAST", "L2", "UNKNOWN"], "description": "Charger speed class. 'DC_FAST' (>=50 kW) suits a dining stop; 'L2' is slow (overnight only); 'UNKNOWN' for Google Places fallback chargers with no power data." },
                              "is_fast_charger": { "type": "boolean", "description": "True when charger_speed is DC_FAST." },
                              "status": { "type": "string" },
                              "compatibility_notes": { "type": "string", "nullable": true },
                              "openchargemap_url": { "type": "string" }
                            }
                          },
                          "distance": {
                            "type": "object",
                            "properties": {
                              "straight_line_metres": { "type": "number" },
                              "estimated_walking_time_minutes": { "type": "integer" },
                              "google_maps_walking_url": { "type": "string" }
                            }
                          },
                          "other_close_chargers": {
                            "type": "array",
                            "description": "Other chargers also within walking distance of this restaurant, sorted by distance. Omitted when none exist.",
                            "items": {
                              "type": "object",
                              "properties": {
                                "name": { "type": "string" },
                                "openchargemap_url": { "type": "string" },
                                "straight_line_metres": { "type": "number" },
                                "estimated_walking_time_minutes": { "type": "integer" }
                              }
                            }
                          }
                        }
                      }
                    },
                    "diagnostics": {
                      "type": "object",
                      "properties": {
                        "qualifying_chargers": { "type": "integer" },
                        "qualifying_restaurant_charger_pairs": { "type": "integer" },
                        "tier_counts": {
                          "type": "object",
                          "description": "Number of returned results in each recommendation tier (keys: primary, distant_good, slow_charger, fast_food, other).",
                          "additionalProperties": { "type": "integer" }
                        },
                        "warnings": { "type": "array", "items": { "type": "string" } }
                      }
                    }
                  }
                }
              }
            }
          },
          "422": {
            "description": "Validation Error",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/HTTPValidationError"
                }
              }
            }
          }
        }
      }
    }
  },
  "components": {
    "schemas": {
      "FindDiningChargersRequest": {
        "properties": {
          "latitude": {
            "type": "number",
            "maximum": 90.0,
            "minimum": -90.0,
            "title": "Latitude",
            "description": "Latitude of the search centre in decimal degrees. Geocode the user's location if they provided a city or place name."
          },
          "longitude": {
            "type": "number",
            "maximum": 180.0,
            "minimum": -180.0,
            "title": "Longitude",
            "description": "Longitude of the search centre in decimal degrees. Geocode the user's location if they provided a city or place name."
          },
          "radius_km": {
            "type": "number",
            "maximum": 100.0,
            "exclusiveMinimum": 0.0,
            "title": "Radius Km",
            "default": 10,
            "description": "Search radius in kilometres around the centre point. Default 10 km is suitable for a town; increase for rural areas."
          },
          "restaurant_radius_m": {
            "type": "integer",
            "maximum": 2000.0,
            "exclusiveMinimum": 0.0,
            "title": "Restaurant Radius M",
            "default": 500,
            "description": "Maximum walking distance in metres between a charger and a restaurant. Default 500 m (~6 min walk). Set to 2000 to also surface the 'distant_good' fallback tier."
          },
          "preferred_radius_m": {
            "type": "integer",
            "maximum": 2000.0,
            "exclusiveMinimum": 0.0,
            "title": "Preferred Radius M",
            "default": 800,
            "description": "Comfortable walking distance in metres separating a 'primary' recommendation from the 'distant_good' fallback. Default 800 m (~10 min walk). Clamped to restaurant_radius_m."
          },
          "nacs": {
            "type": "boolean",
            "title": "Nacs",
            "default": true,
            "description": "Include NACS (North American Charging Standard / Tesla-compatible) chargers."
          },
          "ccs": {
            "type": "boolean",
            "title": "Ccs",
            "default": true,
            "description": "Include CCS (Combined Charging System) DC fast chargers."
          },
          "tesla_only": {
            "type": "boolean",
            "title": "Tesla Only",
            "default": false,
            "description": "Restrict results to Tesla Supercharger network only. Overrides nacs and ccs filters when true."
          },
          "include_fast_food": {
            "type": "boolean",
            "title": "Include Fast Food",
            "default": true,
            "description": "Include fast-food/chain restaurants in results (still labeled via reviews.is_fast_food and the 'fast_food' tier). Set false to exclude them entirely. Keep true so the fast-food fallback tier is available when no good independent restaurant exists."
          },
          "max_results": {
            "type": "integer",
            "maximum": 200,
            "exclusiveMinimum": 0,
            "title": "Max Results",
            "default": 30,
            "description": "Maximum number of charger-restaurant pairs to return. Keep low (10-15) to avoid response size limits."
          }
        },
        "additionalProperties": false,
        "type": "object",
        "required": [
          "latitude",
          "longitude"
        ],
        "title": "FindDiningChargersRequest"
      },
      "HTTPValidationError": {
        "properties": {
          "detail": {
            "items": {
              "$ref": "#/components/schemas/ValidationError"
            },
            "type": "array",
            "title": "Detail"
          }
        },
        "type": "object",
        "title": "HTTPValidationError"
      },
      "ValidationError": {
        "properties": {
          "loc": {
            "items": {
              "anyOf": [
                {
                  "type": "string"
                },
                {
                  "type": "integer"
                }
              ]
            },
            "type": "array",
            "title": "Location"
          },
          "msg": {
            "type": "string",
            "title": "Message"
          },
          "type": {
            "type": "string",
            "title": "Error Type"
          },
          "input": {
            "title": "Input"
          },
          "ctx": {
            "type": "object",
            "title": "Context"
          }
        },
        "type": "object",
        "required": [
          "loc",
          "msg",
          "type"
        ],
        "title": "ValidationError"
      }
    }
  }
}
