OPENCHARGEMAP_API_KEY=your_openchargemap_api_key
GEOAPIFY_API_KEY=your_geoapify_api_key
GEMINI_API_KEY=your_gemini_api_key
GEMINI_MODEL=gemini-2.5-flash-lite
# Optional: Yelp Fusion API key for restaurant ratings/reviews (commercial API — requires a paid plan).
# Leave blank or remove to run without review enrichment.
YELP_API_KEY=your_yelp_api_key
# Optional: Google Places API key for restaurant ratings/reviews (requires a Google Cloud project
# with the Places API enabled; has a free monthly credit).
# Used only when YELP_API_KEY is not set. Leave blank to skip.
GOOGLE_PLACES_API_KEY=your_google_places_api_key
# Set to false to disable review enrichment even if a review API key is configured.
ENABLE_REVIEWS=true
